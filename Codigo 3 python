# Cálculo de la energía cinética
def calcular_energia_cinetica(masa, velocidad):
    energia_cinetica = 0.5 * masa * (velocidad ** 2)
    return energia_cinetica

# Ejemplo de uso
masa = float(input("Ingresa la masa (kg): "))
velocidad = float(input("Ingresa la velocidad (m/s): "))
Ec = calcular_energia_cinetica(masa, velocidad)
print(f"La energía cinética es: {Ec} Joules")
